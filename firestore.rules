rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data : {};
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isClubAdmin() {
      return isSignedIn() && getUserData().role == 'club';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isScoutRole() {
      return isSignedIn() && getUserData().role == 'scout';
    }

    function isStaffRole() {
      return isSignedIn() && getUserData().role in ['coach', 'assistant_coach', 'analyst', 'gk_coach'];
    }

    function isMemberOfClub(clubId) {
      return exists(/databases/$(database)/documents/club_members/$(request.auth.uid + '_' + clubId));
    }

    function isActiveMemberOfClub(clubId) {
      let memberPath = /databases/$(database)/documents/club_members/$(request.auth.uid + '_' + clubId);
      return exists(memberPath) && get(memberPath).data.status == 'active';
    }

    function isClubOwner(clubId) {
      return isSignedIn() && clubId == ('club_' + request.auth.uid);
    }

    function isClubOwnerOfMatch() {
      return isClubOwner(resource.data.clubId);
    }

    function isClubStaffOrOwner(clubId) {
      return isClubOwner(clubId) || isActiveMemberOfClub(clubId);
    }

    // ----------------------------------------------------------------------
    // Users
    // FIX: Restrict read — users can read their own doc; scouts/coaches/admins
    //      can read for legitimate recruitment/management purposes only.
    //      Previously: any signed-in user could read ALL user PII.
    // ----------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isScoutRole() || isStaffRole() || isClubAdmin();
      allow create: if isOwner(userId) || isClubAdmin() || isAdmin();
      allow update: if isOwner(userId) || isAdmin() || isClubAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ----------------------------------------------------------------------
    // Athletes
    // Athletes are discoverable by scouts/coaches but sensitive fields
    // are protected by not being stored in the public athlete doc.
    // ----------------------------------------------------------------------
    match /athletes/{athleteId} {
      allow read: if isSignedIn();
      allow create: if isOwner(athleteId);
      allow update: if isOwner(athleteId) || isScoutRole() || isClubAdmin() || isAdmin() || isStaffRole();
      allow delete: if isOwner(athleteId) || isAdmin();

      match /scout_reports/{reportId} {
        allow read, list: if isSignedIn() && (isScoutRole() || isStaffRole() || isAdmin() || isOwner(athleteId));
        allow create: if isSignedIn() && isScoutRole() && request.resource.data.scoutId == request.auth.uid;
        allow delete: if isSignedIn() && (resource.data.scoutId == request.auth.uid || isAdmin());
        allow update: if false;
      }
    }

    match /scouts/{scoutId} {
      allow read: if isSignedIn();
      allow create: if isOwner(scoutId) || isClubAdmin() || isAdmin();
      allow update, delete: if isOwner(scoutId) || isAdmin() || isClubAdmin();
    }

    // ----------------------------------------------------------------------
    // Clubs
    // ----------------------------------------------------------------------
    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && clubId == ('club_' + request.auth.uid);
      allow update: if isSignedIn() && (
        clubId == ('club_' + request.auth.uid) ||
        isActiveMemberOfClub(clubId) ||
        isAdmin()
      );
      allow delete: if isAdmin();

      match /squad_messages/{msgId} {
        allow read, create: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) ||
          isActiveMemberOfClub(clubId) ||
          get(/databases/$(database)/documents/athletes/$(request.auth.uid)).data.affiliatedClubId == clubId
        );
      }

      match /push_subscriptions/{subId} {
        allow read, write: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) ||
          isActiveMemberOfClub(clubId)
        );
      }

      match /notification_history/{histId} {
        allow read, write: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) ||
          isActiveMemberOfClub(clubId)
        );
      }

      match /pendingMembers/{memberId} {
        allow read, list: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) || isAdmin()
        );
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) || isAdmin()
        );
      }

      match /squad/{memberId} {
        allow read, list: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) ||
          isActiveMemberOfClub(clubId) ||
          isAdmin()
        );
        allow write: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) ||
          isActiveMemberOfClub(clubId) ||
          isAdmin()
        );
      }

      match /drill_library/{drillId} {
        allow read: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) ||
          isActiveMemberOfClub(clubId) ||
          isAdmin()
        );
        allow write: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) ||
          isActiveMemberOfClub(clubId) ||
          isAdmin() ||
          isStaffRole()
        );
      }
    }

    match /club_members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        (
          request.resource.data.userId == request.auth.uid &&
          (
            request.resource.data.role == 'admin' ||
            (request.resource.data.status == 'pending' && request.resource.data.role in ['scout', 'coach', 'assistant_coach', 'analyst', 'gk_coach'])
          )
        ) ||
        (isClubAdmin() && request.resource.data.status == 'club_invited') ||
        (isClubAdmin() && request.resource.data.status == 'active') ||
        (isClubAdmin() && request.resource.data.role == 'athlete') ||
        isAdmin()
      );
      allow update: if isAdmin() || isClubAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || isClubAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid &&
          (resource.data.status == 'pending' || resource.data.status == 'club_invited'));
    }

    // ----------------------------------------------------------------------
    // Matches
    // ----------------------------------------------------------------------
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.athleteId == request.auth.uid ||
        isClubOwner(request.resource.data.clubId) ||
        isActiveMemberOfClub(request.resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );
      allow update, delete: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isClubOwnerOfMatch() ||
        isActiveMemberOfClub(resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );

      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          isClubAdmin() ||
          isActiveMemberOfClub(get(/databases/$(database)/documents/matches/$(matchId)).data.clubId) ||
          isAdmin()
        );
        allow update: if isSignedIn() && (
          resource.data.submittedBy == request.auth.uid || isAdmin()
        );
      }
    }

    // FIX: live_matches / live_match_events were open to any signed-in user.
    //      Now restricted to club staff and owners only.
    match /live_matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isClubOwner(request.resource.data.clubId) ||
        isActiveMemberOfClub(request.resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );
    }

    match /live_match_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isStaffRole() || isClubAdmin() || isAdmin());
      allow update: if isSignedIn() && (isStaffRole() || isClubAdmin() || isAdmin());
      allow delete: if isAdmin() || isClubAdmin();
    }

    // FIX: match_invitations were fully open. Now restrict writes to staff/admins.
    match /match_invitations/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isStaffRole() || isClubAdmin() || isAdmin()
      );
      allow create: if isSignedIn() && (isStaffRole() || isClubAdmin() || isAdmin());
      allow update: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isStaffRole() || isClubAdmin() || isAdmin()
      );
      allow delete: if isAdmin() || isClubAdmin();
    }

    match /squad_invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isClubAdmin() || isStaffRole());
      allow update: if isSignedIn() && (
        isClubAdmin() || isStaffRole() ||
        request.auth.uid == resource.data.athleteId
      );
      allow delete: if isAdmin() || isClubAdmin();
    }

    match /match_confirmations/{confirmId} {
      allow read: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isClubAdmin() || isStaffRole() || isAdmin()
      );
      allow create: if isSignedIn() && (isClubAdmin() || isStaffRole());
      allow update: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isClubAdmin() || isAdmin()
      );
      allow delete: if isAdmin() || isClubAdmin();
    }

    match /practices/{practiceId} {
      allow read: if isSignedIn();
      allow create: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(request.resource.data.clubId));
      allow update: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(resource.data.clubId));
      allow delete: if isClubAdmin() || isAdmin();
    }

    match /drills/{drillId} {
      allow read: if isSignedIn();
      allow create: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(request.resource.data.clubId));
      allow update: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(resource.data.clubId));
      allow delete: if isClubAdmin() || isAdmin();
    }

    match /training_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(request.resource.data.clubId));
      allow update: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(resource.data.clubId));
      allow delete: if isClubAdmin() || isAdmin();
    }

    // ----------------------------------------------------------------------
    // Connections & Messaging
    // ----------------------------------------------------------------------
    match /scout_connections/{connectionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.scoutId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.scoutId ||
        request.auth.uid == request.resource.data.athleteId ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.scoutId);

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/scout_connections/$(connectionId)).data.scoutId ||
          request.auth.uid == get(/databases/$(database)/documents/scout_connections/$(connectionId)).data.athleteId ||
          isAdmin()
        );
      }
    }

    // FIX: club_conversations were fully open. Now restricted to club members and owners.
    match /club_conversations/{conversationId} {
      allow read: if isSignedIn() && (
        isClubAdmin() || isStaffRole() || isAdmin() ||
        isActiveMemberOfClub(resource.data.clubId)
      );
      allow create: if isSignedIn() && (isClubAdmin() || isStaffRole() || isAdmin());
      allow update: if isSignedIn() && (isClubAdmin() || isStaffRole() || isAdmin());

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          isClubAdmin() || isStaffRole() || isAdmin() ||
          isActiveMemberOfClub(get(/databases/$(database)/documents/club_conversations/$(conversationId)).data.clubId)
        );
        allow write: if isSignedIn() && (isClubAdmin() || isStaffRole() || isAdmin());
      }
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (
        resource == null ||
        request.auth.uid in resource.data.participants ||
        (resource.data.type == 'group' && resource.data.clubId != null &&
          isActiveMemberOfClub(resource.data.clubId)) ||
        (resource.data.type == 'group' && isClubOwner(resource.data.clubId)) ||
        (resource.data.type == 'group' && conversationId == ('club_' + request.auth.uid))
      );

      allow create: if isSignedIn() && (
        request.auth.uid in request.resource.data.participants ||
        request.resource.data.type == 'group' ||
        isClubAdmin() ||
        isStaffRole()
      );

      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid in request.resource.data.participants ||
        (resource.data.type == 'group' && resource.data.clubId != null &&
          (isActiveMemberOfClub(resource.data.clubId) || isClubOwner(resource.data.clubId))) ||
        isClubAdmin() ||
        isStaffRole()
      );

      match /messages/{messageId} {
        function convData() {
          return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
        }
        function inConv() {
          let d = convData();
          return d != null && request.auth.uid in d.participants;
        }
        function inGroupConv() {
          let d = convData();
          return d != null && d.type == 'group' && d.clubId != null && (
            isActiveMemberOfClub(d.clubId) || isClubOwner(d.clubId)
          );
        }
        function isSquadChat() {
          return conversationId == ('club_' + request.auth.uid) ||
                 (convData() != null && convData().type == 'group');
        }
        function canWriteToConv() {
          let d = convData();
          return inConv() ||
                 inGroupConv() ||
                 isSquadChat() ||
                 (isClubAdmin() && d != null && d.type == 'group') ||
                 (isStaffRole() && d != null && d.type == 'group');
        }
        allow read: if isSignedIn() && (inConv() || inGroupConv() || isClubAdmin() || isStaffRole() || isSquadChat());
        allow create: if isSignedIn() && canWriteToConv() &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && (
          resource.data.senderId == request.auth.uid ||
          (isClubAdmin() && convData().type == 'group') ||
          (isStaffRole() && convData().type == 'group')
        );
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // ----------------------------------------------------------------------
    // Support Tickets (Admin Client Support Dashboard)
    // ----------------------------------------------------------------------
    match /support_tickets/{ticketId} {
      allow read, list: if isAdmin();
      allow create: if isAdmin() || isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read, list: if isAdmin() ||
          (isSignedIn() && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.senderUserId == request.auth.uid);
        allow create: if isAdmin() ||
          (isSignedIn() && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.senderUserId == request.auth.uid);
        allow update, delete: if isAdmin();
      }

      match /internalNotes/{noteId} {
        allow read, list, create, update, delete: if isAdmin();
      }
    }

    // Legacy support threads
    match /support_threads/{threadId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource == null ||
        resource.data.userId == request.auth.uid ||
        resource.data.adminId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.adminId == request.auth.uid
      );

      match /messages/{msgId} {
        // FIX: Was fully open to any signed-in user. Now restricted to thread participants.
        allow read, write: if isSignedIn() && (
          isAdmin() ||
          get(/databases/$(database)/documents/support_threads/$(threadId)).data.userId == request.auth.uid
        );
      }
    }

    // ----------------------------------------------------------------------
    // Marketing (Admin Marketing Dashboard)
    // ----------------------------------------------------------------------
    match /marketing_segments/{segmentId} {
      allow read, list, create, update, delete: if isAdmin();
    }

    match /marketing_campaigns/{campaignId} {
      allow read, list, create, update, delete: if isAdmin();
    }

    match /marketing_automations/{automationId} {
      allow read, list, create, update, delete: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // Admin / Platform
    // ----------------------------------------------------------------------
    match /scoutData/{scoutId}/privateNotes/{athleteId} {
      allow read, write: if isOwner(scoutId);
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /waiting_list/{entryId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /verification_requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.targetUid == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /contact_inquiries/{docId} {
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 200 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() <= 5000;
      allow read, update, delete: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // Profiles, Reactions, Comments, Notifications
    // ----------------------------------------------------------------------
    match /profile_views/{athleteId}/viewers/{viewerId} {
      allow create, update: if isSignedIn();
      allow read: if isOwner(athleteId);
      allow list: if isOwner(athleteId);
    }

    match /notifications/{userId}/items/{notificationId} {
      allow read, list: if isOwner(userId);
      allow create: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /profile_reactions/{reactionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /profile_comments/{athleteId}/comments/{commentId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || isOwner(athleteId)
      );
    }

    match /video_reactions/{reactionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /video_comments/{videoId}/comments/{commentId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // ----------------------------------------------------------------------
    // Direct Messages (coach ↔ athlete / staff 1:1 threads)
    // ----------------------------------------------------------------------
    match /messages/{messageId} {
      allow read, list: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid ||
        resource.data.senderId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // Announcements (club-wide broadcast posts from coaches / admins)
    // ----------------------------------------------------------------------
    match /announcements/{clubId}/posts/{postId} {
      allow read, list: if isSignedIn() && (
        isActiveMemberOfClub(clubId) ||
        clubId == ('club_' + request.auth.uid) ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        isActiveMemberOfClub(clubId) ||
        clubId == ('club_' + request.auth.uid) ||
        isStaffRole() ||
        isAdmin()
      );
      allow update, delete: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        clubId == ('club_' + request.auth.uid) ||
        isAdmin()
      );
    }

    // ----------------------------------------------------------------------
    // Schedule Events (coach schedule page)
    // ----------------------------------------------------------------------
    match /schedule_events/{eventId} {
      allow read, list: if isSignedIn() && (
        isActiveMemberOfClub(resource.data.clubId) ||
        resource.data.clubId == ('club_' + request.auth.uid) ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        isActiveMemberOfClub(request.resource.data.clubId) ||
        request.resource.data.clubId == ('club_' + request.auth.uid) ||
        isStaffRole() ||
        isAdmin()
      );
      allow update, delete: if isSignedIn() && (
        isActiveMemberOfClub(resource.data.clubId) ||
        resource.data.clubId == ('club_' + request.auth.uid) ||
        isStaffRole() ||
        isAdmin()
      );
    }

    // ----------------------------------------------------------------------
    // Verifications (athlete stat verification requests from coaches)
    // ----------------------------------------------------------------------
    match /verifications/{verificationId} {
      allow read, list: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isActiveMemberOfClub(resource.data.clubId) ||
        resource.data.clubId == ('club_' + request.auth.uid) ||
        isStaffRole() ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        isActiveMemberOfClub(request.resource.data.clubId) ||
        request.resource.data.clubId == ('club_' + request.auth.uid) ||
        isStaffRole() ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isActiveMemberOfClub(resource.data.clubId) ||
        resource.data.clubId == ('club_' + request.auth.uid) ||
        isStaffRole() ||
        isAdmin()
      );
      allow delete: if isAdmin() || isClubAdmin();
    }

    // ----------------------------------------------------------------------
    // ghost_players — unregistered players with coach-entered match stats
    // ----------------------------------------------------------------------
    match /ghost_players/{ghostId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        isStaffRole() ||
        isActiveMemberOfClub(resource.data.clubId) ||
        resource.data.clubId == ('club_' + request.auth.uid) ||
        resource.data.coachId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        isStaffRole() ||
        isActiveMemberOfClub(request.resource.data.clubId) ||
        request.resource.data.clubId == ('club_' + request.auth.uid) ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        isStaffRole() ||
        resource.data.coachId == request.auth.uid ||
        isActiveMemberOfClub(resource.data.clubId) ||
        request.auth.uid == resource.data.claimedBy
      );
      allow delete: if isAdmin() || resource.data.coachId == request.auth.uid;
    }
  }
}
