rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    // Safe getUserData — returns {} when the user doc doesn't exist so callers
    // that access .role get null instead of a null-pointer error.
    function getUserData() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data : {};
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isClubAdmin() {
      return isSignedIn() && getUserData().role == 'club';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isScoutRole() {
      return isSignedIn() && getUserData().role == 'scout';
    }

    function isStaffRole() {
      return isSignedIn() && getUserData().role in ['coach', 'assistant_coach', 'analyst', 'gk_coach'];
    }

    function isMemberOfClub(clubId) {
      return exists(/databases/$(database)/documents/club_members/$(request.auth.uid + '_' + clubId));
    }

    function isActiveMemberOfClub(clubId) {
      let memberPath = /databases/$(database)/documents/club_members/$(request.auth.uid + '_' + clubId);
      return exists(memberPath) && get(memberPath).data.status == 'active';
    }

    // True if the club document ID encodes this user's UID (club_<uid>)
    function isClubOwner(clubId) {
      return isSignedIn() && clubId == ('club_' + request.auth.uid);
    }

    // Check if the current user owns the club associated with a match
    function isClubOwnerOfMatch() {
      return isClubOwner(resource.data.clubId);
    }

    // ----------------------------------------------------------------------
    // Standard Collection Rules
    // ----------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /athletes/{athleteId} {
      allow read: if isSignedIn();
      allow create: if isOwner(athleteId);
      allow update: if isOwner(athleteId) || isScoutRole() || isClubAdmin() || isAdmin() ||
        isStaffRole();
      allow delete: if isOwner(athleteId) || isAdmin();
    }
    
    match /scouts/{scoutId} {
        allow read: if isSignedIn();
        allow create: if isOwner(scoutId);
        allow update, delete: if isOwner(scoutId) || isAdmin();
    }

    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && clubId == ('club_' + request.auth.uid);
      allow update: if isSignedIn() && (
        clubId == ('club_' + request.auth.uid) ||
        isActiveMemberOfClub(clubId) ||
        isAdmin()
      );
      allow delete: if isAdmin();

      // Squad Chat Subcollection
      match /squad_messages/{msgId} {
        allow read, create: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) || 
          isActiveMemberOfClub(clubId) ||
          get(/databases/$(database)/documents/athletes/$(request.auth.uid)).data.affiliatedClubId == clubId
        );
      }

      // Push Notification Subscriptions
      match /push_subscriptions/{subId} {
        allow read, write: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) ||
          isActiveMemberOfClub(clubId)
        );
      }

      // Notification History
      match /notification_history/{histId} {
        allow read, write: if isSignedIn() && (
          clubId == ('club_' + request.auth.uid) ||
          isActiveMemberOfClub(clubId)
        );
      }
    }

    match /club_members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        // Users creating their own membership (admin setup or a pending join request)
        (
          request.resource.data.userId == request.auth.uid &&
          (
            request.resource.data.role == 'admin' ||
            (request.resource.data.status == 'pending' && request.resource.data.role in ['scout', 'coach', 'assistant_coach', 'analyst', 'gk_coach'])
          )
        ) ||
        // Club admins sending invitations to scouts or coaches
        (
          isClubAdmin() &&
          request.resource.data.status == 'club_invited'
        ) ||
        // Club admins directly adding athletes or staff (immediate active status)
        (
          isClubAdmin() &&
          request.resource.data.status == 'active'
        ) ||
        // Club admins directly adding athletes with athlete role
        (
          isClubAdmin() &&
          request.resource.data.role == 'athlete'
        )
      );
      // Club admins and system admins can approve/reject/update any record
      allow update: if isAdmin() || isClubAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || isClubAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid &&
          (resource.data.status == 'pending' || resource.data.status == 'club_invited'));
    }

    // Matches: athletes own their match entries; club admins and coaches own club fixtures
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.athleteId == request.auth.uid ||
        isClubOwner(request.resource.data.clubId) ||
        isActiveMemberOfClub(request.resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );
      allow update, delete: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isClubOwnerOfMatch() ||
        isActiveMemberOfClub(resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );

      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          isClubAdmin() ||
          isActiveMemberOfClub(get(/databases/$(database)/documents/matches/$(matchId)).data.clubId) ||
          isAdmin()
        );
        allow update: if isSignedIn() && (
          resource.data.submittedBy == request.auth.uid || isAdmin()
        );
      }
    }

    match /live_matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /live_match_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /match_invitations/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Squad invites sent by coaches/club admins to athletes
    match /squad_invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isClubAdmin() || isStaffRole());
      allow update: if isSignedIn() && (
        isClubAdmin() || isStaffRole() ||
        request.auth.uid == resource.data.athleteId
      );
      allow delete: if isAdmin() || isClubAdmin();
    }

    // Match confirmations written by coaches when saving match data
    match /match_confirmations/{confirmId} {
      allow read: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isClubAdmin() || isStaffRole() || isAdmin()
      );
      allow create: if isSignedIn() && (isClubAdmin() || isStaffRole());
      allow update: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isClubAdmin() || isAdmin()
      );
      allow delete: if isAdmin() || isClubAdmin();
    }

    match /practices/{practiceId} {
      allow read: if isSignedIn();
      allow create: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(request.resource.data.clubId));
      allow update: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(resource.data.clubId));
      allow delete: if isClubAdmin() || isAdmin();
    }

    match /drills/{drillId} {
      allow read: if isSignedIn();
      allow create: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(request.resource.data.clubId));
      allow update: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(resource.data.clubId));
      allow delete: if isClubAdmin() || isAdmin();
    }

    match /training_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(request.resource.data.clubId));
      allow update: if isClubAdmin() || isAdmin() || isStaffRole() ||
        (isSignedIn() && isActiveMemberOfClub(resource.data.clubId));
      allow delete: if isClubAdmin() || isAdmin();
    }

    // Squad Invites — sent by coaches/club admins to athletes
    match /squad_invites/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isActiveMemberOfClub(resource.data.clubId) ||
        isClubOwner(resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        isActiveMemberOfClub(request.resource.data.clubId) ||
        isClubOwner(request.resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isActiveMemberOfClub(resource.data.clubId) ||
        isClubOwner(resource.data.clubId) ||
        isAdmin()
      );
      allow delete: if isAdmin() || isClubOwner(resource.data.clubId);
    }

    // Match Confirmations — created by coaches/staff, confirmed by athletes
    match /match_confirmations/{confirmId} {
      allow read: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isActiveMemberOfClub(resource.data.clubId) ||
        isClubOwner(resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        isActiveMemberOfClub(request.resource.data.clubId) ||
        isClubOwner(request.resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isActiveMemberOfClub(resource.data.clubId) ||
        isStaffRole() ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /scout_connections/{connectionId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn() && request.resource.data.scoutId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.scoutId || 
        request.auth.uid == request.resource.data.athleteId ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.scoutId);

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/scout_connections/$(connectionId)).data.scoutId || 
          request.auth.uid == get(/databases/$(database)/documents/scout_connections/$(connectionId)).data.athleteId ||
          isAdmin()
        );
      }
    }

    match /club_conversations/{conversationId} {
      allow read, create, update: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // ----------------------------------------------------------------------
    // Universal Messaging: Direct Messages + Club Group Chats
    // ----------------------------------------------------------------------
    match /conversations/{conversationId} {
      // Read: allow when doc doesn't exist yet (resource == null handles getDoc on
      // non-existent docs — resource.data would crash rules otherwise), OR the user
      // is a participant, OR it's a group chat they're an active member of.
      allow read: if isSignedIn() && (
        resource == null ||
        request.auth.uid in resource.data.participants ||
        (resource.data.type == 'group' && resource.data.clubId != null &&
          isActiveMemberOfClub(resource.data.clubId)) ||
        (resource.data.type == 'group' && isClubOwner(resource.data.clubId))
      );

      // Create: any signed-in user creating a DM they're part of, OR any signed-in
      // user creating a group chat (group chats are club-scoped, admin enforced app-side)
      allow create: if isSignedIn() && (
        request.auth.uid in request.resource.data.participants ||
        request.resource.data.type == 'group'
      );

      // Update: participant can update DMs; any club member or club owner can update group chats.
      // Also allow update when the sender is in request.resource.data.participants — this covers
      // setDoc merge calls that self-heal older conversations missing participants.
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid in request.resource.data.participants ||
        (resource.data.type == 'group' && resource.data.clubId != null &&
          (isActiveMemberOfClub(resource.data.clubId) || isClubOwner(resource.data.clubId)))
      );

      match /messages/{messageId} {
        function convData() {
          return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
        }
        function inConv() {
          return request.auth.uid in convData().participants;
        }
        function inGroupConv() {
          let d = convData();
          return d != null && d.type == 'group' && d.clubId != null && (
            isActiveMemberOfClub(d.clubId) || isClubOwner(d.clubId)
          );
        }
        // isClubAdmin() is an explicit bypass: a user whose role == 'club' can
        // always write to any group conversation they are broadcasting to.
        // This covers the case where the club_members document path doesn't
        // match the expected pattern and isClubOwner()/isActiveMemberOfClub()
        // would otherwise fail.
        function canWriteToConv() {
          let d = convData();
          return inConv() ||
                 inGroupConv() ||
                 (isClubAdmin() && d != null && d.type == 'group');
        }
        allow read: if isSignedIn() && (inConv() || inGroupConv() || isClubAdmin());
        allow create: if isSignedIn() && canWriteToConv() &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && (
          resource.data.senderId == request.auth.uid ||
          (isClubAdmin() && convData().type == 'group')
        );
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    match /support_threads/{threadId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource == null ||
        resource.data.userId == request.auth.uid || 
        resource.data.adminId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid || 
        resource.data.adminId == request.auth.uid
      );

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    match /scoutData/{scoutId}/privateNotes/{athleteId} {
      allow read, write: if isOwner(scoutId);
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /waiting_list/{entryId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    match /verification_requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.targetUid == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // Contact Form — public create, admin read/manage
    // ----------------------------------------------------------------------
    match /contact_inquiries/{docId} {
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 200 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() <= 5000;
      allow read, update, delete: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // Profile View Tracking
    // ----------------------------------------------------------------------
    match /profile_views/{athleteId}/viewers/{viewerId} {
      allow create, update: if isSignedIn();
      allow read: if isOwner(athleteId);
      allow list: if isOwner(athleteId);
    }

    // ----------------------------------------------------------------------
    // Notifications
    // ----------------------------------------------------------------------
    match /notifications/{userId}/items/{notificationId} {
      allow read, list: if isOwner(userId);
      allow create: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ----------------------------------------------------------------------
    // Profile Reactions (Likes)
    // ----------------------------------------------------------------------
    match /profile_reactions/{reactionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ----------------------------------------------------------------------
    // Profile Comments
    // ----------------------------------------------------------------------
    match /profile_comments/{athleteId}/comments/{commentId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || isOwner(athleteId)
      );
    }

    // ----------------------------------------------------------------------
    // Club Subcollections (pendingMembers, squad)
    // ----------------------------------------------------------------------
    match /clubs/{clubId}/pendingMembers/{memberId} {
      allow read, list: if isSignedIn() && (
        clubId == ('club_' + request.auth.uid) || isAdmin()
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        clubId == ('club_' + request.auth.uid) || isAdmin()
      );
    }

    match /clubs/{clubId}/squad/{memberId} {
      allow read, list: if isSignedIn() && (
        clubId == ('club_' + request.auth.uid) ||
        isActiveMemberOfClub(clubId) ||
        isAdmin()
      );
      allow write: if isSignedIn() && (
        clubId == ('club_' + request.auth.uid) ||
        isActiveMemberOfClub(clubId) ||
        isAdmin()
      );
    }

    match /clubs/{clubId}/drill_library/{drillId} {
      allow read: if isSignedIn() && (
        clubId == ('club_' + request.auth.uid) ||
        isActiveMemberOfClub(clubId) ||
        isAdmin()
      );
      allow write: if isSignedIn() && (
        clubId == ('club_' + request.auth.uid) ||
        isActiveMemberOfClub(clubId) ||
        isAdmin() ||
        isStaffRole()
      );
    }

    // ----------------------------------------------------------------------
    // Video Reactions (Likes on highlight videos)
    // ----------------------------------------------------------------------
    match /video_reactions/{reactionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ----------------------------------------------------------------------
    // Video Comments (Comments on highlight videos)
    // ----------------------------------------------------------------------
    match /video_comments/{videoId}/comments/{commentId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
  }
}
